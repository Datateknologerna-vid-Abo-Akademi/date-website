############################################################
#
# Edit these values to match your development environment
#
#                 DO NOT REMOVE THESE!!
#
############################################################

# [Docker]

# Sets docker compose project name to use
COMPOSE_PROJECT_NAME="datewebsite"

# Compose file used by plain `docker compose ...` commands
COMPOSE_FILE="docker-compose.yml"

# [Postgres]

# PostgreSQL version to use. DO NOT change this manually after the database has been created!!!
DATE_POSTGRESQL_VERSION=16

# DB password
DATE_DB_PASSWORD="password"

# [pgAdmin]

# Optional Compose profiles. Set to "pgadmin" to include pgAdmin.
COMPOSE_PROFILES=""

# Browser URL when pgAdmin is enabled: http://localhost:5050
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL="admin@example.com"
PGADMIN_DEFAULT_PASSWORD="password"

# [Django]

# Sets the project name which determines which settings will be used
PROJECT_NAME="date"

# Django port
DATE_DJANGO_PORT=8000

# Django secret key (keep production secret)
DATE_SECRET_KEY="wowsuchsecret"

# Debug django (set to False in prod)
DATE_DEBUG=True

# Set django DEVELOP setting (set to False in prod)
DATE_DEVELOP=True

# Enable public/admin language features such as the language switcher and
# translated admin tabs. Defaults to False when omitted.
ENABLE_LANGUAGE_FEATURES=False

# Allowed hosts
ALLOWED_HOSTS='["0.0.0.0", "127.0.0.1", "localhost"]'

# Allowed origins for csrf
ALLOWED_ORIGINS='["https://localhost", "http://localhost", "https://localhost:8000", "http://localhost:8000"]'

# Trust forwarded host/proto headers from a reverse proxy or ingress
USE_X_FORWARDED_HOST=False
TRUST_X_FORWARDED_PROTO=False

# Extra staff groups
EXTRA_STAFF_GROUPS='["example_group", "example_group2"]'

ALUMNI_SETTINGS='{}'

# [Email]

# The email that should receive notifications
EMAIL_HOST_RECEIVER='info@datateknologerna.org'

# Default email to send from
DEFAULT_FROM_EMAIL='admin@datateknologerna.org'

# Email server to send from
EMAIL_HOST='smtp.gmail.com'

# Email user
EMAIL_HOST_USER=''

# Email password
EMAIL_HOST_PASSWORD=''

# [Redis]

# Redis URL used by Django cache/channels
REDIS_SERVER="redis://redis:6379"

# Redis URLs used by Celery
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/0"

# [S3]

# If you want to USE S3 (empty string for False, eg: '')
USE_S3=''

# S3 endpoint url
# Backblaze B2 example: https://s3.<region>.backblazeb2.com
S3_ENDPOINT_URL="http://s3:9000"

# S3 access key
S3_ACCESS_KEY="key"

# S3 secret key
S3_SECRET_KEY="password"

# S3 bucket name
S3_BUCKET_NAME="date-images"

# Optional separate private/public buckets for S3-compatible providers such as Backblaze B2
S3_PRIVATE_BUCKET_NAME=""
S3_PUBLIC_BUCKET_NAME=""

# Optional S3-compatible provider settings
# For Backblaze B2, region should match the endpoint region, e.g. us-west-000
S3_REGION_NAME=""
S3_SIGNATURE_VERSION="s3v4"
S3_ADDRESSING_STYLE="path"

# Private media location (example: date/media or kk/media)
PRIVATE_MEDIA_LOCATION="date/media"

# Public media location  (example: date/public or kk/public)
PUBLIC_MEDIA_LOCATION="date/public"

# Cloudflare captcha keys, set to '' to disable captcha
CF_TURNSTILE_SITE_KEY=""
CF_TURNSTILE_SECRET_KEY=""

# [GitHub OAuth]
# Create an OAuth App at https://github.com/settings/developers
# Set the callback URL to: http://localhost:8000/members/github/callback/
# Leave empty to disable GitHub login
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Controls when local site 2FA is still required after GitHub login:
# - enrolled: require local 2FA for users who have enabled it on this site
# - staff: require local 2FA only for staff/admin users who have enabled it
# - off: never require local 2FA after GitHub login
GITHUB_MFA_POLICY="enrolled"

# Docker tag to use when pulling images.
# Use a release tag like v1.2.3 in production. Branch tags such as master/develop are also published for non-release builds.
DATE_IMG_TAG="master"
